<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora Interactiva</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .calculator-card {
            background-color: #ffffff;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            width: 100%;
            max-width: 450px;
        }

        h2 {
            text-align: center;
            color: #333;
            margin-bottom: 30px;
            font-size: 28px;
        }

        .input-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-size: 14px;
            font-weight: 600;
        }

        input[type="number"] {
            width: 100%;
            padding: 14px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 16px;
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        input[type="number"]:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .btn-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-top: 30px;
        }

        button {
            padding: 14px;
            font-size: 16px;
            font-weight: bold;
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: background-color 0.3s, transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
        }

        button:active {
            transform: translateY(0);
        }

        .btn-sumar {
            background-color: #2ecc71;
            grid-column: 1;
        }
        .btn-sumar:hover {
            background-color: #27ae60;
        }

        .btn-restar {
            background-color: #e74c3c;
            grid-column: 2;
        }
        .btn-restar:hover {
            background-color: #c0392b;
        }

        .btn-multiplicar {
            background-color: #f39c12;
            grid-column: 1;
        }
        .btn-multiplicar:hover {
            background-color: #d35400;
        }

        .btn-dividir {
            background-color: #3498db;
            grid-column: 2;
        }
        .btn-dividir:hover {
            background-color: #2980b9;
        }

        .btn-borrar {
            background-color: #7f8c8d;
            grid-column: span 2;
            margin-top: 10px;
            font-size: 14px;
        }
        .btn-borrar:hover {
            background-color: #5d6d7b;
        }

        .result-box {
            margin-top: 30px;
            padding: 20px;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            border-left: 6px solid #667eea;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }

        .result-box p {
            font-size: 14px;
            color: #666;
            margin-bottom: 10px;
        }

        .result-box span {
            display: block;
            font-size: 36px;
            font-weight: bold;
            color: #333;
            word-break: break-all;
        }

        .error {
            color: #e74c3c !important;
        }

        .success {
            color: #2ecc71 !important;
        }

        @media (max-width: 480px) {
            .calculator-card {
                padding: 25px;
            }

            h2 {
                font-size: 24px;
                margin-bottom: 20px;
            }

            .result-box span {
                font-size: 28px;
            }
        }
    </style>
</head>
<body>

    <div class="calculator-card">
        <h2>🧮 Calculadora</h2>
       
        <div class="input-group">
            <label for="num1">Primer Número</label>
            <input type="number" id="num1" placeholder="Ej. 12" step="any">
        </div>

        <div class="input-group">
            <label for="num2">Segundo Número</label>
            <input type="number" id="num2" placeholder="Ej. 4" step="any">
        </div>

        <div class="btn-container">
            <button class="btn-sumar" onclick="calcular('sumar')">➕ Sumar</button>
            <button class="btn-restar" onclick="calcular('restar')">➖ Restar</button>
            <button class="btn-multiplicar" onclick="calcular('multiplicar')">✖️ Multiplicar</button>
            <button class="btn-dividir" onclick="calcular('dividir')">➗ Dividir</button>
            <button class="btn-borrar" onclick="borrarCampos()">🔄 Borrar Todo</button>
        </div>

        <div class="result-box">
            <p>Resultado:</p>
            <span id="resultado">0</span>
        </div>
    </div>

    <script>
        function calcular(operacion) {
            const input1 = document.getElementById('num1');
            const input2 = document.getElementById('num2');
            const contenedorResultado = document.getElementById('resultado');

            // Convertimos a números flotantes
            const n1 = parseFloat(input1.value);
            const n2 = parseFloat(input2.value);

            // Validación: Verificar si los campos están vacíos o no son válidos
            if (isNaN(n1) || !input1.value.trim() || isNaN(n2) || !input2.value.trim()) {
                contenedorResultado.innerText = "❌ Ingresa ambos números";
                contenedorResultado.className = "error";
                return;
            }

            let resultado = 0;
            let esValido = true;

            switch (operacion) {
                case 'sumar':
                    resultado = n1 + n2;
                    break;
                case 'restar':
                    resultado = n1 - n2;
                    break;
                case 'multiplicar':
                    resultado = n1 * n2;
                    break;
                case 'dividir':
                    // Validación para evitar división entre cero
                    if (n2 === 0) {
                        contenedorResultado.innerText = "❌ No se puede dividir por 0";
                        contenedorResultado.className = "error";
                        esValido = false;
                        return;
                    }
                    resultado = n1 / n2;
                    break;
            }

            if (esValido) {
                // Muestra el resultado final (limitando a 10 decimales si es necesario)
                const resultadoFinal = Math.round(resultado * 10000000000) / 10000000000;
                contenedorResultado.innerText = resultadoFinal;
                contenedorResultado.className = "success";
            }
        }

        // Función para borrar y resetear los campos
        function borrarCampos() {
            const input1 = document.getElementById('num1');
            const input2 = document.getElementById('num2');
            const contenedorResultado = document.getElementById('resultado');

            // Limpia los valores de texto de los inputs
            input1.value = "";
            input2.value = "";

            // Restablece el recuadro de resultados
            contenedorResultado.innerText = "0";
            contenedorResultado.className = "";

            // Coloca el cursor automáticamente en el primer input
            input1.focus();
        }

        // Permitir calcular con Enter
        document.getElementById('num2').addEventListener('keypress', function(event) {
            if (event.key === 'Enter') {
                calcular('sumar');
            }
        });
    </script>

</body>
</html>